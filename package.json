{
  "name": "syto-edtech-platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev:frontend": "vite",
    "dev:api": "npx dotenv-cli -e .env.development -- tsx --watch src/api/server.ts",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:api\"",
    "build": "vite build",
    "build:api": "tsc -p tsconfig.api.json",
    "build:all": "npm run build && npm run build:api",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "node dist-api/api/server.js",
    "start:api": "npx dotenv-cli -e .env.development -- tsx src/api/server.ts",
    "start:all": "concurrently \"npm run preview\" \"npm run start:api\"",
    "ingest-pdfs": "tsx scripts/ingest-pdfs.ts",
    "test-ingestion": "tsx -e \"import('./src/lib/pdf-test.js').then(m => m.runPDFIngestionTests())\"",
    "setup-ingestion": "npm install dotenv tsx",
    "test-comprehensive": "tsx scripts/test-comprehensive-extraction.ts",
    "test-chale-api": "tsx scripts/test-chale-api.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.22",
    "@netlify/functions": "^4.1.8",
