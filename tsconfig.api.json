{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist-api",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2020",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "lib": ["ES2020", "DOM"],
    "types": ["vite/client"]
  },
  "include": ["src/api/**/*", "src/lib/**/*", "src/types/**/*"],
  "exclude": ["node_modules", "dist", "dist-api"]
}
